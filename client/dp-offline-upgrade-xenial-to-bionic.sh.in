PIN_CONFIRM_PHRASE='@@CONFIRM_PHRASE@@'
PIN_GENERATED_AT='@@GENERATED_AT@@'
PIN_PROFILE_NAME='@@PROFILE_NAME@@'

PIN_KEY_B64='@@KEY_B64@@'
PIN_MANIFEST_KEY_B64='@@MANIFEST_KEY_B64@@'
PIN_META_B64='@@META_B64@@'
PIN_MANIFEST_B64='@@MANIFEST_B64@@'
PIN_MANIFEST_SIG_B64='@@MANIFEST_SIG_B64@@'
PIN_ANNOUNCEMENT_B64='@@ANNOUNCEMENT_B64@@'

# Runtime defaults (overridable)
MIRROR_BASE="${PIN_MIRROR_BASE}"
