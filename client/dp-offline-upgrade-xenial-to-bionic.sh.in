PIN_MIRROR_BASE='@@MIRROR_BASE@@'
PIN_HOP='@@HOP@@'
PIN_SOURCE_CODENAME='@@SOURCE_CODENAME@@'
PIN_TARGET_CODENAME='@@TARGET_CODENAME@@'
PIN_SOURCE_VERSION='@@SOURCE_VERSION@@'
PIN_TARGET_VERSION='@@TARGET_VERSION@@'
PIN_COMPONENTS='@@COMPONENTS@@'
PIN_SOURCE_SUITES='@@SOURCE_SUITES@@'
PIN_TARGET_SUITES='@@TARGET_SUITES@@'
PIN_KEY_FINGERPRINT='@@KEY_FINGERPRINT@@'
PIN_KEY_SHA256='@@KEY_SHA256@@'
PIN_MANIFEST_KEY_FINGERPRINT='@@MANIFEST_KEY_FINGERPRINT@@'
PIN_MANIFEST_KEY_SHA256='@@MANIFEST_KEY_SHA256@@'
PIN_META_SHA256='@@META_SHA256@@'
PIN_UPGRADER_TAR_SHA256='@@UPGRADER_TAR_SHA256@@'
PIN_UPGRADER_GPG_SHA256='@@UPGRADER_GPG_SHA256@@'
PIN_PLAN_CHECKSUM='@@PLAN_CHECKSUM@@'
PIN_DISCOVERY_CHECKSUM='@@DISCOVERY_CHECKSUM@@'
PIN_MANIFEST_SHA256='@@MANIFEST_SHA256@@'
