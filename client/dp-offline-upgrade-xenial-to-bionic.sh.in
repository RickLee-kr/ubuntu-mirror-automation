#!/usr/bin/env bash
# dp-offline-upgrade-xenial-to-bionic.sh — single-file offline Xenial→Bionic upgrade
# Generated by: scripts/ubuntu-offline-mirror.sh build-client-xenial-to-bionic
# Target host: Ubuntu 16.04 (Bash 4.3 / systemd 229 / apt 1.2)
#
# Phase 1 — Ubuntu OS-Only Offline Upgrade (UPGRADE_MODE=OS_ONLY_PHASE1).
# Does NOT validate DP product install/topology/services. Does NOT auto-run
# 18.04→20.04 or DP bringup (Phase 2).
set -euo pipefail

SCRIPT_VERSION="1.0.0-xenial-to-bionic"
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || printf '%s' "$0")"

