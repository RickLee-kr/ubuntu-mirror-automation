HOLDS_DIR="${STATE_ROOT}/critical-holds"
COMMIT_BACKUP_PATH=""
COMMIT_STAMP=""
# Legacy APT trusted keyring (Xenial DistUpgrade SourceEntry rejects signed-by=).
LEGACY_APT_KEYRING_PATH="/etc/apt/trusted.gpg.d/stellar-offline-xenial-to-bionic.gpg"
# Kept for backup/restore bookkeeping; DistUpgrade sources must not reference signed-by=.
KEYRING_PATH="${LEGACY_APT_KEYRING_PATH}"
DISTUPGRADE_SOURCES_PATH="${STATE_ROOT}/distupgrade-target.sources.list"
# DistUpgrade ValidMirrors / AllowThirdParty override (official release-upgrades.d).
DISTUPGRADE_MIRRORS_FILE="${STATE_ROOT}/distupgrade-valid-mirrors.cfg"
DISTUPGRADE_OVERRIDE_DIR="/etc/update-manager/release-upgrades.d"
DISTUPGRADE_OVERRIDE_CFG="${DISTUPGRADE_OVERRIDE_DIR}/99-stellar-offline-mirror.cfg"
EFFECTIVE_SOURCE_GATE_BIN="${STATE_ROOT}/bin/distupgrade-effective-source-gate"
EFFECTIVE_SOURCE_GATE_APT="/etc/apt/apt.conf.d/98stellar-distupgrade-source-gate"
# Keep-local conffile policy for unattended dpkg/ucf (applied to DistUpgrade apt too).
NONINTERACTIVE_CONFFILE_APT_CONFIG="/etc/apt/apt.conf.d/97stellar-offline-conffile-policy"
EFFECTIVE_SOURCE_CAPTURE_DIR="${STATE_ROOT}/effective-sources"
# Root-only lifecycle markers (STATE_FILE is a file; markers live beside it under STATE_ROOT).
EFFECTIVE_SOURCE_GATE_ARMED_MARKER="${STATE_ROOT}/effective-source-gate.armed"
EFFECTIVE_SOURCE_GATE_PASSED_MARKER="${STATE_ROOT}/effective-source-gate.passed"
EFFECTIVE_SOURCE_GATE_LOG="/var/log/aella/distupgrade_effective_source_gate.log"
EFFECTIVE_SOURCE_GATE_EVIDENCE_ROOT="${STATE_ROOT}/evidence/effective-source-gate"
META_RELEASE_FILE="/etc/update-manager/meta-release"
RUNNER_PATH="/usr/local/sbin/stellar-offline-os-upgrade-runner"
POSTBOOT_PATH="/usr/local/sbin/stellar-offline-os-upgrade-postboot"
UNIT_NAME="stellar-offline-os-upgrade.service"
POSTBOOT_UNIT_NAME="stellar-offline-os-upgrade-postboot.service"
MIN_ROOT_BYTES=12884901888   # 12 GiB — dp-os-upgrade.conf policy
MIN_BOOT_BYTES=536870912     # 512 MiB
MIN_AELLADATA_BYTES=5368709120 # 5 GiB
MIN_DP_VERSION="6.2.0"       # Phase 2 reference only; not a Phase 1 hard gate
# Phase 1 default: OS upgrade enablement only (product gates never hard-fail).
UPGRADE_PHASE=1
UPGRADE_MODE="OS_ONLY_PHASE1"
