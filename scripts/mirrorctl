#!/usr/bin/env bash
# mirrorctl — Operator CLI for Ubuntu Mirror Server
set -euo pipefail

resolve_libs() {
  if [[ -f /usr/local/lib/ubuntu-mirror/common.sh ]]; then
    # shellcheck source=/dev/null
    source /usr/local/lib/ubuntu-mirror/common.sh
    # shellcheck source=/dev/null
    source /usr/local/lib/ubuntu-mirror/config.sh
    # shellcheck source=/dev/null
    source /usr/local/lib/ubuntu-mirror/state.sh
    # shellcheck source=/dev/null
    source /usr/local/lib/ubuntu-mirror/progress.sh
    UM_SRC_ROOT="/usr/local/lib/ubuntu-mirror"
  else
    UM_SRC_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    # shellcheck source=lib/common.sh
    source "${UM_SRC_ROOT}/lib/common.sh"
    # shellcheck source=lib/config.sh
    source "${UM_SRC_ROOT}/lib/config.sh"
    # shellcheck source=lib/state.sh
    source "${UM_SRC_ROOT}/lib/state.sh"
    # shellcheck source=lib/progress.sh
    source "${UM_SRC_ROOT}/lib/progress.sh"
  fi
}

resolve_libs

UM_CONFIG_ARG=""

usage() {
  cat <<'EOF'
Usage: mirrorctl [--config PATH] <command> [args]

Commands:
  status              Concise operational status snapshot
  watch               Live terminal sync dashboard
  validate            Operational readiness checks
  finalize            After initial sync: cleanup, enable timer, mark ready
  sync [start|stop|status|pause|resume]
  logs [--lines N|--no-follow|--progress|--raw]
  cleanup             Run apt-mirror clean.sh
  nginx [status|test|reload|restart|migrate|recover]
  timer [status|start|stop|enable|disable]
  client [setup|validate]
  restart             Reload systemd + restart nginx
  recover             Auto-recover common failures
  info                Show configuration paths
  help

Sync examples:
  sudo mirrorctl sync start
  sudo mirrorctl sync start --background
  sudo mirrorctl sync start --foreground
  sudo mirrorctl sync stop
  sudo mirrorctl sync pause
  sudo mirrorctl sync resume

Watch examples:
  sudo mirrorctl watch
  sudo mirrorctl watch --foreground
  sudo mirrorctl watch --interval 20
  sudo mirrorctl watch --once
  sudo mirrorctl watch --raw
EOF
}

need_root() { um_require_root; }

dashboard_bin() {
  local dash repo here
  # 1) Git checkout recorded at install time (so git pull applies without reinstall)
  if [[ -f "${INSTALL_CONF_DIR:-/etc/ubuntu-mirror}/source-repo" ]]; then
    repo="$(tr -d '\r\n' <"${INSTALL_CONF_DIR:-/etc/ubuntu-mirror}/source-repo" 2>/dev/null || true)"
    if [[ -n "$repo" ]] && [[ -x "${repo}/scripts/mirror-dashboard.sh" ]]; then
      printf '%s\n' "${repo}/scripts/mirror-dashboard.sh"
      return
    fi
  fi
  # 2) Companion next to this mirrorctl (repo/scripts or /usr/local/bin)
  here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "${here}/mirror-dashboard.sh" ]]; then
    printf '%s\n' "${here}/mirror-dashboard.sh"
    return
  fi
  if [[ -x "${here}/mirror-dashboard" ]]; then
    printf '%s\n' "${here}/mirror-dashboard"
    return
  fi
  # 3) Installed / project fallbacks
  dash="${INSTALL_BIN_DIR}/mirror-dashboard"
  [[ -x "$dash" ]] || dash="${UM_SRC_ROOT}/scripts/mirror-dashboard.sh"
  printf '%s\n' "$dash"
}

cmd_status_selective_hops() {
  local root hops_dir hop
  root="${SELECTIVE_MIRROR_ROOT:-${BASE_PATH}/selective}"
  hops_dir="${root}/published/hops"
  [[ -d "$hops_dir" ]] || hops_dir="${root}/current/hops"
  [[ -d "$hops_dir" ]] || return 0
  echo "Hop repositories:"
  for hop in "$hops_dir"/*; do
    [[ -d "$hop" ]] || continue
    printf -- '- /hops/%s/ubuntu\n' "$(basename "$hop")"
  done
}

cmd_status() {
  local full=0
  local a
  for a in "$@"; do
    [[ "$a" == "--full" ]] && full=1
  done

  UM_QUIET_LOAD=1
  um_evaluate_selective_ready 2>/dev/null || true
  um_detect_sync_health
  local state nginx_state timer_line
  state="${UM_LIFECYCLE_STATE}"

  if systemctl is-active --quiet nginx 2>/dev/null; then
    nginx_state="Running"
  else
    nginx_state="Down"
  fi

  if systemctl is-enabled --quiet apt-mirror.timer 2>/dev/null; then
    timer_line="Enabled (legacy; selective does not use daily full sync)"
  else
    timer_line="Disabled (selective profile)"
  fi

  local install_line="OK"
  um_is_installed || install_line="Incomplete"

  local selective_root="${SELECTIVE_MIRROR_ROOT:-${BASE_PATH}/selective}"
  local nginx_root="${SELECTIVE_NGINX_ROOT:-${selective_root}/current}"
  local mirror_bytes pkgs
  mirror_bytes="$(um_mirror_size_bytes_cached)"
  pkgs="$(um_package_count_cached)"

  local ready_line="NO"
  [[ "${UM_SELECTIVE_READY:-0}" == "1" ]] && ready_line="YES"
  local verified_line="${UM_SELECTIVE_VERIFIED_FILES:-?}"
  if [[ -n "${UM_SELECTIVE_EXPECTED_FILES:-}" ]]; then
    verified_line="${UM_SELECTIVE_VERIFIED_FILES:-?} / ${UM_SELECTIVE_EXPECTED_FILES}"
  fi
  local current_tgt="${UM_SELECTIVE_CURRENT_TARGET:-}"
  [[ -n "$current_tgt" ]] || current_tgt="$(readlink -f "${selective_root}/current" 2>/dev/null || echo missing)"

  cat <<EOF
Profile: offline-upgrade-selective
Installation: ${install_line}
State: ${state}
Health: ${UM_HEALTH_STATE}
Reason: ${UM_HEALTH_REASON}
Selective root: ${selective_root}
Materialize: ${UM_SELECTIVE_MATERIALIZE:-NOT_RUN}
Downloaded: ${UM_SELECTIVE_DOWNLOADED:--}
Existing verified: ${UM_SELECTIVE_EXISTS:--}
Expected .deb: ${UM_SELECTIVE_EXPECTED_DEB:-${pkgs}}
Verified files: ${verified_line}
Unresolved: ${UM_SELECTIVE_UNRESOLVED:--}
Checksum failures: ${UM_SELECTIVE_CHECKSUM_FAILS:--}
Pre-publish verify: ${UM_SELECTIVE_VERIFY:-NOT_RUN}
Publish: ${UM_SELECTIVE_PUBLISH:-NOT_RUN}
Post-publish HTTP: ${UM_SELECTIVE_POST_HTTP:-NOT_RUN}
Nginx: ${nginx_state}
Nginx root: ${nginx_root}
Nginx config: ${UM_SELECTIVE_NGINX_CONFIG:--}
Nginx HTTP: ${UM_SELECTIVE_NGINX_HTTP:--}
Current target: ${current_tgt}
READY: ${ready_line}
Mirror size: $(um_format_bytes "${mirror_bytes:-0}")
Packages: ${pkgs} .deb files
Timer: ${timer_line}
Mirror base: ${MIRROR_URL%/}/
EOF
  cmd_status_selective_hops
  cat <<EOF
Dashboard: sudo mirrorctl watch
EOF

  if [[ "$full" -eq 1 ]]; then
    local uom="${INSTALL_BIN_DIR:-/usr/local/bin}/ubuntu-offline-mirror"
    [[ -x "$uom" ]] || uom="/usr/local/sbin/ubuntu-offline-mirror.sh"
    [[ -x "$uom" ]] || uom="${UM_SRC_ROOT}/scripts/ubuntu-offline-mirror.sh"
    if [[ -x "$uom" ]] || [[ -f "$uom" ]]; then
      echo "---- selective status ----"
      bash "$uom" status 2>/dev/null || true
    fi
    local bin="${INSTALL_BIN_DIR}/mirror-status"
    [[ -x "$bin" ]] || bin="${INSTALL_BIN_DIR}/mirror-status.sh"
    [[ -x "$bin" ]] || bin="${UM_SRC_ROOT}/scripts/mirror-status.sh"
    if [[ -x "$bin" ]]; then
      "$bin" --config "${UM_CONFIG_PATH}" || true
    fi
  fi
}

cmd_watch() {
  local dash args=()
  dash="$(dashboard_bin)"
  [[ -x "$dash" ]] || um_die "mirror-dashboard not found at $dash"

  # Default attach is foreground TUI; --background just prints hints
  local mode="foreground"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --foreground) mode="foreground"; shift ;;
      --background)
        printf 'Sync dashboard not attached (--background).\n'
        printf 'Use: sudo mirrorctl watch\n'
        return 0
        ;;
      *) args+=("$1"); shift ;;
    esac
  done
  : "$mode"
  UM_QUIET_LOAD=1
  exec "$dash" --config "${UM_CONFIG_PATH}" "${args[@]+"${args[@]}"}"
}

cmd_validate() {
  local bin project_root
  project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  bin="${INSTALL_BIN_DIR}/validate.sh"
  [[ -x "$bin" ]] || bin="${project_root}/validate.sh"
  "$bin" --config "${UM_CONFIG_PATH}" --mode operational "$@"
}

cmd_finalize() {
  need_root
  if um_is_sync_running; then
    um_die "Selective materialize is still running — wait for completion"
  fi
  local selective_ready="${BASE_PATH}/selective/state/READY"
  if [[ ! -f "$selective_ready" ]]; then
    um_die "Selective READY missing — run verify-selective + publish-selective first"
  fi

  mkdir -p "$LOG_DIR"
  local flog
  flog="$(um_finalize_log_path)"
  log_step() {
    printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" | tee -a "$flog"
  }

  um_mark_state "finalizing"
  log_step "[OK] Selective mirror verify/publish complete"
  log_step "[RUNNING] Ensuring apt-mirror.timer stays disabled (selective profile)"
  systemctl daemon-reload
  systemctl disable apt-mirror.timer >/dev/null 2>&1 || true
  systemctl stop apt-mirror.timer >/dev/null 2>&1 || true
  log_step "[OK] Daily full-sync timer disabled"

  um_mark_state "initial-sync-complete"
  um_mark_state "ready"
  um_clear_marker "sync-failed"
  um_clear_marker "finalizing"
  log_step "[OK] Mirror state READY (selective)"

  printf '\nSelective mirror is READY.\n'
  cmd_status
}

cmd_sync() {
  local action="status"
  local mode="background"
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      start|stop|status|pause|resume)
        action="$1"
        shift
        ;;
      --foreground) mode="foreground"; shift ;;
      --background) mode="background"; shift ;;
      *) args+=("$1"); shift ;;
    esac
  done

  case "$action" in
    start)
      need_root
      # Never invoke legacy full apt-mirror sync under selective profile.
      if um_evaluate_selective_ready 2>/dev/null && [[ "${UM_SELECTIVE_READY:-0}" == "1" ]]; then
        um_ok "Selective mirror already READY — not restarting materialize"
        um_ok "Reason: ${UM_SELECTIVE_READY_REASON}"
        um_ok "To force rematerialize: remove READY only after an intentional republish plan"
        cmd_status
        return 0
      fi
      if ! um_check_sync_capacity "$BASE_PATH" "$MIRROR_MODE"; then
        um_die "Sync blocked by disk capacity / safety reserve check" 2
      fi
      if um_is_sync_running; then
        um_ok "Selective materialize already running"
      else
        # apt-mirror.service ExecStart runs materialize-selective under selective profile.
        if [[ -f /etc/systemd/system/apt-mirror.service ]] \
          && ! grep -q 'materialize-selective' /etc/systemd/system/apt-mirror.service 2>/dev/null; then
          um_die "apt-mirror.service still points at legacy sync — run: sudo ./scripts/ubuntu-offline-mirror.sh migrate-selective-runtime"
        fi
        systemctl start --no-block apt-mirror.service
        um_mark_state "sync-started"
        um_ok "Started selective materialize via apt-mirror.service"
      fi
      if [[ "$mode" == "foreground" ]]; then
        cmd_watch --foreground
      else
        cat <<EOF
Selective materialize started in background.

Attach dashboard:
  sudo mirrorctl watch

Check status:
  sudo mirrorctl status

Follow logs:
  sudo mirrorctl logs
EOF
      fi
      ;;
    stop)
      need_root
      systemctl kill -s SIGCONT apt-mirror.service 2>/dev/null || true
      systemctl stop apt-mirror.service 2>/dev/null || true
      # Stop selective materialize/verify helpers (never leave orphan downloads).
      pkill -f 'ubuntu-offline-mirror\.sh[[:space:]]+(materialize-selective|verify-selective|publish-selective)' 2>/dev/null || true
      pkill -f 'selective_mirror\.py[[:space:]]+materialize' 2>/dev/null || true
      pkill -f '/usr/bin/perl /usr/bin/apt-mirror' 2>/dev/null || true
      um_ok "Stop requested for selective materialize. Dashboard detach does not stop sync."
      ;;
    pause)
      need_root
      if ! um_is_sync_running && ! pgrep -f 'run-apt-mirror\.sh' >/dev/null 2>&1; then
        um_die "No running sync to pause"
      fi
      # KillMode=control-group: SIGSTOP reaches apt-mirror children
      systemctl kill -s SIGSTOP apt-mirror.service 2>/dev/null || true
      local pid
      for pid in $(um_apt_mirror_pids); do
        kill -STOP "$pid" 2>/dev/null || true
      done
      if um_is_sync_paused; then
        um_progress_event pause "reason=mirrorctl"
        um_ok "Sync paused (SIGSTOP). Resume with: sudo mirrorctl sync resume"
      else
        um_warn "Pause: not supported safely by this apt-mirror runtime"
        um_warn "Processes may not have entered the stopped state"
      fi
      ;;
    resume)
      need_root
      systemctl kill -s SIGCONT apt-mirror.service 2>/dev/null || true
      local pid
      for pid in $(um_apt_mirror_pids); do
        kill -CONT "$pid" 2>/dev/null || true
      done
      um_progress_event resume "reason=mirrorctl"
      um_ok "Sync resumed (SIGCONT)"
      ;;
    status)
      if um_is_sync_paused; then
        echo "Sync: paused"
      elif um_is_sync_running; then
        echo "Sync: running"
      else
        echo "Sync: not running (state=$(um_detect_lifecycle_state))"
      fi
      systemctl status apt-mirror.service --no-pager -l 2>/dev/null | head -20 || true
      ;;
    *) um_die "sync args: start|stop|status|pause|resume [--foreground|--background]" ;;
  esac
}

cmd_logs() {
  local lines=100
  local follow=1
  local progress=0
  local raw=0
  local which="sync"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lines)
        lines="${2:-100}"
        shift 2
        ;;
      --no-follow) follow=0; shift ;;
      --progress) progress=1; shift ;;
      --raw) raw=1; shift ;;
      sync|nginx|install|follow|progress)
        which="$1"
        shift
        ;;
      *)
        # Compatibility: bare number or subcommand
        if [[ "$1" =~ ^[0-9]+$ ]]; then
          lines="$1"
          shift
        else
          which="$1"
          shift
        fi
        ;;
    esac
  done

  if [[ "$which" == "follow" ]]; then
    follow=1
    which="sync"
  fi
  if [[ "$which" == "progress" ]] || [[ "$progress" -eq 1 ]]; then
    local pj
    pj="$(um_progress_jsonl_path)"
    if [[ ! -f "$pj" ]]; then
      um_warn "No progress log yet: $pj"
      return 0
    fi
    if [[ "$follow" -eq 1 ]]; then
      tail -n "$lines" -f "$pj"
    else
      tail -n "$lines" "$pj"
    fi
    return 0
  fi

  case "$which" in
    sync|"")
      # Prefer selective offline-mirror log, then journal, then legacy apt-mirror.log.
      local sel_log="${LOG_FILE:-/var/log/ubuntu-offline-mirror.log}"
      local sel_state_log="${SELECTIVE_MIRROR_ROOT:-${BASE_PATH}/selective}/logs"
      if [[ -d "$sel_state_log" ]]; then
        local newest
        newest="$(ls -1t "$sel_state_log"/*.log 2>/dev/null | head -1 || true)"
        [[ -n "$newest" ]] && sel_log="$newest"
      fi
      if [[ "$raw" -eq 1 ]] && [[ -f "$APT_MIRROR_LOG" ]]; then
        if [[ "$follow" -eq 1 ]]; then
          tail -n "$lines" -f "$APT_MIRROR_LOG"
        else
          tail -n "$lines" "$APT_MIRROR_LOG"
        fi
      elif [[ -f "$sel_log" ]]; then
        if [[ "$follow" -eq 1 ]]; then
          tail -n "$lines" -f "$sel_log"
        else
          tail -n "$lines" "$sel_log"
        fi
      else
        if [[ "$follow" -eq 1 ]]; then
          journalctl -u apt-mirror.service -n "$lines" -f
        else
          journalctl -u apt-mirror.service -n "$lines" --no-pager
        fi
      fi
      ;;
    nginx)
      [[ -f "$NGINX_ACCESS_LOG" ]] && tail -n 50 "$NGINX_ACCESS_LOG"
      [[ -f "$NGINX_ERROR_LOG" ]] && tail -n 50 "$NGINX_ERROR_LOG"
      ;;
    install) tail -n "$lines" "${LOG_DIR}/install.log" 2>/dev/null || um_warn "missing" ;;
    *) um_die "logs options: [--lines N] [--no-follow] [--progress] [--raw] [sync|nginx|install]" ;;
  esac
}

cmd_cleanup() {
  need_root
  [[ -x "$CLEAN_SCRIPT" ]] || um_die "clean.sh missing at $CLEAN_SCRIPT"
  bash "$CLEAN_SCRIPT"
  um_ok "Cleanup finished"
}

cmd_nginx() {
  local action="${1:-status}"
  local site_en="/etc/nginx/sites-enabled/${NGINX_SITE_NAME:-apt-mirror}"
  local expected="${SELECTIVE_NGINX_ROOT:-${SELECTIVE_MIRROR_ROOT:-${BASE_PATH}/selective}/current}"
  case "$action" in
    status)
      systemctl status nginx --no-pager || true
      if [[ -e "$site_en" ]]; then
        echo "config: $(readlink -f "$site_en" 2>/dev/null || echo "$site_en")"
        awk '/^[[:space:]]*root /{print; exit}' "$(readlink -f "$site_en" 2>/dev/null || echo "$site_en")" 2>/dev/null || true
        echo "expected_selective_root: $expected"
      fi
      ;;
    test) nginx -t ;;
    reload) need_root; nginx -t && systemctl reload nginx && um_ok "reloaded" ;;
    restart) need_root; nginx -t && systemctl restart nginx && um_ok "restarted" ;;
    migrate)
      need_root
      local uom=""
      for uom in \
        "${UM_PROJECT_ROOT:-}/scripts/ubuntu-offline-mirror.sh" \
        /usr/local/sbin/ubuntu-offline-mirror.sh \
        "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/ubuntu-offline-mirror.sh"
      do
        [[ -x "$uom" ]] && break
        uom=""
      done
      [[ -n "$uom" ]] || um_die "ubuntu-offline-mirror.sh not found"
      bash "$uom" migrate-nginx-selective
      ;;
    recover)
      need_root
      systemctl restart nginx
      nginx -t
      um_ok "nginx recovered"
      ;;
    *) um_die "nginx args: status|test|reload|restart|migrate|recover" ;;
  esac
}

cmd_timer() {
  local action="${1:-status}"
  case "$action" in
    status) systemctl list-timers apt-mirror.timer --no-pager || true ;;
    start) need_root; systemctl start apt-mirror.timer; um_ok "timer started" ;;
    stop) need_root; systemctl stop apt-mirror.timer; um_ok "timer stopped" ;;
    enable) need_root; systemctl enable --now apt-mirror.timer; um_ok "timer enabled" ;;
    disable) need_root; systemctl disable --now apt-mirror.timer; um_ok "timer disabled" ;;
    *) um_die "timer args: status|start|stop|enable|disable" ;;
  esac
}

cmd_client() {
  local action="${1:-}"
  shift || true
  local project_root setup_bin validate_bin
  project_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  setup_bin="${INSTALL_BIN_DIR}/client-setup.sh"
  validate_bin="${INSTALL_BIN_DIR}/client-validate.sh"
  [[ -x "$setup_bin" ]] || setup_bin="${project_root}/client/client-setup.sh"
  [[ -x "$validate_bin" ]] || validate_bin="${project_root}/client/client-validate.sh"
  case "$action" in
    setup) "$setup_bin" --mirror-url "${MIRROR_URL}" "$@" ;;
    validate) "$validate_bin" --mirror-url "${MIRROR_URL}" "$@" ;;
    "") echo "Mirror URL: ${MIRROR_URL}/ubuntu" ;;
    *) um_die "client args: setup|validate" ;;
  esac
}

cmd_restart() {
  need_root
  systemctl daemon-reload
  nginx -t
  systemctl restart nginx
  um_ok "restarted"
}

cmd_recover() {
  need_root
  local bin="${INSTALL_BIN_DIR}/mirror-recovery"
  [[ -x "$bin" ]] || bin="${INSTALL_BIN_DIR}/mirror-recovery.sh"
  [[ -x "$bin" ]] || bin="${UM_SRC_ROOT}/scripts/mirror-recovery.sh"
  "$bin" --config "${UM_CONFIG_PATH}" "$@"
}

cmd_info() {
  cat <<EOF
Config:      ${UM_CONFIG_PATH}
Base path:   ${BASE_PATH}
Mirror URL:  ${MIRROR_URL}/ubuntu
Mode:        ${MIRROR_MODE}
Versions:    ${UBUNTU_VERSIONS}
State:       $(um_detect_lifecycle_state)
Progress:    $(um_progress_jsonl_path)
Dashboard:   sudo mirrorctl watch
EOF
}

main() {
  local cmd="" args=() filtered=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        UM_CONFIG_ARG="${2:-}"
        [[ -n "$UM_CONFIG_ARG" ]] || um_die "--config requires a path"
        shift 2
        ;;
      -h|--help) usage; exit 0 ;;
      *) filtered+=("$1"); shift ;;
    esac
  done
  set -- "${filtered[@]+"${filtered[@]}"}"
  while [[ $# -gt 0 ]]; do
    if [[ -z "$cmd" ]]; then cmd="$1"; else args+=("$1"); fi
    shift
  done
  [[ -n "$cmd" ]] || { usage; exit 1; }
  [[ "$cmd" == "help" ]] && { usage; exit 0; }

  um_load_config "$UM_CONFIG_ARG"
  um_set_log_file "${LOG_DIR}/mirrorctl.log"
  um_ensure_log_dir

  case "$cmd" in
    status)   cmd_status "${args[@]+"${args[@]}"}" ;;
    watch)    cmd_watch "${args[@]+"${args[@]}"}" ;;
    validate) cmd_validate "${args[@]+"${args[@]}"}" ;;
    finalize) cmd_finalize ;;
    sync)     cmd_sync "${args[@]+"${args[@]}"}" ;;
    logs)     cmd_logs "${args[@]+"${args[@]}"}" ;;
    cleanup)  cmd_cleanup ;;
    nginx)    cmd_nginx "${args[@]+"${args[@]}"}" ;;
    timer)    cmd_timer "${args[@]+"${args[@]}"}" ;;
    client)   cmd_client "${args[@]+"${args[@]}"}" ;;
    restart)  cmd_restart ;;
    recover)  cmd_recover "${args[@]+"${args[@]}"}" ;;
    info)     cmd_info ;;
    *) um_die "Unknown command: $cmd" ;;
  esac
}

main "$@"
